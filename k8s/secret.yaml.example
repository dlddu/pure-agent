# mcp container
apiVersion: v1
kind: Secret
metadata:
  name: mcp-server-secrets
type: Opaque
stringData:
  LINEAR_API_KEY: "your-linear-api-key"
  LINEAR_TEAM_ID: "your-linear-team-id"

---

# llm-gateway container
apiVersion: v1
kind: Secret
metadata:
  name: llm-gateway-secrets
type: Opaque
stringData:
  CLAUDE_CODE_OAUTH_TOKEN: "your-claude-code-oauth-token"
  LITELLM_MASTER_KEY: "your-litellm-master-key"

---

# agent container
apiVersion: v1
kind: Secret
metadata:
  name: agent-secrets
type: Opaque
stringData:
  LITELLM_MASTER_KEY: "your-litellm-master-key"

---

# export-handler container
apiVersion: v1
kind: Secret
metadata:
  name: export-handler-secrets
type: Opaque
stringData:
  LINEAR_API_KEY: "your-linear-api-key"
  LINEAR_TEAM_ID: "your-linear-team-id"
  GITHUB_TOKEN: "your-github-token"
