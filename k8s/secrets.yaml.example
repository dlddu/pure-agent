# mcp container
apiVersion: v1
kind: Secret
metadata:
  name: mcp-server-secrets
type: Opaque
stringData:
  LINEAR_API_KEY: "your-linear-api-key"
  LINEAR_TEAM_ID: "your-linear-team-id"
  GATEKEEPER_URL: "https://gatekeeper.example.com"
  GATEKEEPER_API_KEY: "your-gatekeeper-api-key"
  GATEKEEPER_USER_ID: "your-gatekeeper-user-id"
  # Optional — required to enable the get_exchange_rates MCP tool.
  AWS_S3_BUCKET_NAME: "your-s3-bucket-name"
  EXCHANGE_RATES_ROLE_ARN: "arn:aws:iam::ACCOUNT_ID:role/your-exchange-rates-role"

---

# agent container
apiVersion: v1
kind: Secret
metadata:
  name: agent-secrets
type: Opaque
stringData:
  CLAUDE_CODE_OAUTH_TOKEN: "your-claude-code-oauth-token"

---

# gate container
apiVersion: v1
kind: Secret
metadata:
  name: gate-secrets
type: Opaque
stringData:
  AWS_S3_BUCKET_NAME: "your-s3-bucket-name"
  AWS_ASSUME_ROLE_ARN: "arn:aws:iam::ACCOUNT_ID:role/your-upload-role"
  AWS_S3_PREFIX: "transcripts"

---

# planner container
apiVersion: v1
kind: Secret
metadata:
  name: planner-secrets
type: Opaque
stringData:
  CLAUDE_CODE_OAUTH_TOKEN: "your-claude-code-oauth-token"

---

# export-handler container
apiVersion: v1
kind: Secret
metadata:
  name: export-handler-secrets
type: Opaque
stringData:
  LINEAR_API_KEY: "your-linear-api-key"
  GITHUB_TOKEN: "your-github-token"
