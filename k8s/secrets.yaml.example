# mcp container
apiVersion: v1
kind: Secret
metadata:
  name: mcp-server-secrets
type: Opaque
stringData:
  LINEAR_API_KEY: "your-linear-api-key"
  LINEAR_TEAM_ID: "your-linear-team-id"
  GATEKEEPER_URL: "https://gatekeeper.example.com"
  GATEKEEPER_API_KEY: "your-gatekeeper-api-key"
  GATEKEEPER_USER_ID: "your-gatekeeper-user-id"

---

# agent container
apiVersion: v1
kind: Secret
metadata:
  name: agent-secrets
type: Opaque
stringData:
  CLAUDE_CODE_OAUTH_TOKEN: "your-claude-code-oauth-token"

---

# gate container
apiVersion: v1
kind: Secret
metadata:
  name: gate-secrets
type: Opaque
stringData:
  AWS_S3_BUCKET_NAME: "your-s3-bucket-name"

---

# planner container
apiVersion: v1
kind: Secret
metadata:
  name: planner-secrets
type: Opaque
stringData:
  ANTHROPIC_API_KEY: "your-anthropic-api-key"

---

# export-handler container
apiVersion: v1
kind: Secret
metadata:
  name: export-handler-secrets
type: Opaque
stringData:
  LINEAR_API_KEY: "your-linear-api-key"
  GITHUB_TOKEN: "your-github-token"
