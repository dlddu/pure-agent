# Server Configuration
PORT=8080
HOST=0.0.0.0
MCP_PATH=/mcp

# Linear Configuration (Required - provided via External Secret)
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINEAR_TEAM_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Linear Configuration (Optional)
LINEAR_DEFAULT_PROJECT_ID=
LINEAR_DEFAULT_LABEL_ID=

# Gatekeeper Configuration (Required for web_fetch_get approval)
GATEKEEPER_URL=https://gatekeeper.example.com
GATEKEEPER_API_KEY=gk_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

GATEKEEPER_USER_ID=user-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gatekeeper Configuration (Optional)
GATEKEEPER_POLL_INTERVAL_MS=2000
GATEKEEPER_TIMEOUT_MS=300000

# Shared S3 configuration (used by S3-backed tools such as get_exchange_rates)
AWS_S3_BUCKET_NAME=
AWS_REGION=ap-northeast-2

# Exchange rates tool — IAM role ARN to assume for reading gold/exchange_rates/*
EXCHANGE_RATES_ROLE_ARN=
